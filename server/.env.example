# Railway PostgreSQL — copy from Railway dashboard > your DB service > Connect
DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway

# OnlyFans API (from onlyfansapi.com)
ONLYFANS_API_KEY=

# OnlyTraffic API
ONLYTRAFFIC_API_KEY=

# Airtable (optional)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=

# Port (Railway sets this automatically)
PORT=3000

# Frontend origin for CORS — your Vercel/Railway frontend URL
FRONTEND_ORIGIN=http://localhost:5173
