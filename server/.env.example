# Railway PostgreSQL — copy from Railway dashboard > your DB service > Connect
DATABASE_URL=postgresql://user:password@host.railway.internal:5432/railway

# OnlyFans API (from onlyfansapi.com)
ONLYFANS_API_KEY=

# OnlyTraffic API
ONLYTRAFFIC_API_KEY=

# Airtable (optional)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=

# Port (Railway sets this automatically)
PORT=3000

# Public URL of this server — used by the orchestrator to call /sync/account internally
# On Railway: set to your Railway service public URL (e.g. https://upbeat-bravery.up.railway.app)
SERVER_URL=http://localhost:3000

# Frontend origin for CORS — comma-separated list of allowed origins
FRONTEND_ORIGIN=http://localhost:8080,http://localhost:5173,https://your-app.vercel.app
